Cell[CellGroupData[{
Cell["\<\
Revisiting a random model of lateral gene transfer in phylogenetics\
\>", "Title",
 CellChangeTimes->{{3.9907077341535053`*^9, 
  3.990707747898203*^9}},ExpressionUUID->"da1f7ed1-55d0-4b43-bc57-\
40ae5a256915"],

Cell["Laura Kubatko, Simone Linz, and Kristina Wicke (2026)", "Subtitle",
 CellChangeTimes->{{3.990707766483015*^9, 3.990707774698472*^9}, {
  3.9907079095853233`*^9, 
  3.990707911554256*^9}},ExpressionUUID->"a38882ef-107c-4779-9092-\
8201485a4673"],

Cell["\<\
This Mathematica notebook accompanies the manuscript and provides the full \
set of calculations underlying the results presented in the main text.
\
\>", "Text",
 CellChangeTimes->{{3.990707783399745*^9, 3.990707817272016*^9}, {
   3.990707905186235*^9, 3.99070790555921*^9}, 
   3.9907079478617487`*^9},ExpressionUUID->"d4f451e3-552f-4dcd-8fbd-\
f6334ddb464b"],

Cell[CellGroupData[{

Cell["The 2-taxon case", "Chapter",
 CellChangeTimes->{{3.990707938353981*^9, 
  3.990707944257406*^9}},ExpressionUUID->"0620a2f2-bbcb-44e4-98c2-\
6cf800449946"],

Cell["\<\
Species tree: T = (1, 2)
Arc notation: for i = 1,2, e_i denotes the arc incident to leaf i.
Furthermore, t1 denotes the t-value of the interior vertex of T, h the \
t-value of the relevant transfer event, and g the t-value of the interior \
vertex of the resulting gene histories.\
\>", "Text",
 CellChangeTimes->{{3.990708016755619*^9, 3.9907080493203*^9}, {
  3.990708513385694*^9, 3.990708528730523*^9}, {3.990712618438101*^9, 
  3.990712639813435*^9}, {3.992932984322236*^9, 
  3.9929329880295773`*^9}},ExpressionUUID->"92109ffb-dfa1-4d42-a029-\
16ca9661c689"],

Cell[CellGroupData[{

Cell["Gene history densities", "Section",
 CellChangeTimes->{{3.9907079852974997`*^9, 
  3.990708001891293*^9}},ExpressionUUID->"f67a998f-537b-4a51-a249-\
d95ab0e57299"],

Cell["H0: No transfer event; g=t1", "Text",
 CellChangeTimes->{{3.990708072992363*^9, 3.9907080853128023`*^9}, 
   3.990712798254075*^9},ExpressionUUID->"7202f532-e852-4321-9cd3-\
ec085978cdda"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"fH0", " ", "=", " ", 
  RowBox[{"Exp", "[", 
   RowBox[{
    RowBox[{"-", "2"}], " ", "*", "\[Lambda]", "*", "t1"}], "]"}]}]], "Input",\

 CellChangeTimes->{{3.990708095183258*^9, 3.9907080955136013`*^9}, 
   3.990712644971115*^9},
 CellLabel->"In[69]:=",ExpressionUUID->"7c95d3af-e532-4389-a41f-3f8eb5210dea"],

Cell[BoxData[
 SuperscriptBox["\[ExponentialE]", 
  RowBox[{
   RowBox[{"-", "2"}], " ", "t1", " ", "\[Lambda]"}]]], "Output",
 CellChangeTimes->{
  3.990708097107717*^9, {3.990712647113882*^9, 3.990712662046012*^9}},
 CellLabel->"Out[69]=",ExpressionUUID->"8a56fdee-6483-4adb-807f-b16d8fff2937"]
}, Open  ]],

Cell["\<\
H1: Precisely one relevant transfer in (0,t1) with transfer arc from e1 to e2 \
or from e2 to e1; g=h; 0 < h < t1.\
\>", "Text",
 CellChangeTimes->{{3.990708106297248*^9, 3.990708108542306*^9}, {
  3.9907127997396317`*^9, 
  3.9907128019715023`*^9}},ExpressionUUID->"aafc26e2-0ca7-4ebf-af33-\
f0afc4224443"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"fH1", " ", "=", " ", 
  RowBox[{"2", " ", "*", " ", 
   RowBox[{"1", "/", "2"}], " ", "*", " ", "2", " ", "*", " ", "\[Lambda]", 
   " ", "*", " ", 
   RowBox[{"Exp", "[", 
    RowBox[{
     RowBox[{"-", "2"}], "*", "\[Lambda]", "*", "h"}], "]"}]}]}]], "Input",
 CellChangeTimes->{{3.99070812154539*^9, 3.9907081217684183`*^9}},
 CellLabel->"In[70]:=",ExpressionUUID->"7c7aefc6-5209-4346-affd-c236c917b845"],

Cell[BoxData[
 RowBox[{"2", " ", 
  SuperscriptBox["\[ExponentialE]", 
   RowBox[{
    RowBox[{"-", "2"}], " ", "h", " ", "\[Lambda]"}]], " ", 
  "\[Lambda]"}]], "Output",
 CellChangeTimes->{
  3.9907081233083143`*^9, {3.990712651900772*^9, 3.99071266330468*^9}},
 CellLabel->"Out[70]=",ExpressionUUID->"2bd3060a-33f1-4f0d-812e-b3f58ef274ad"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Gene tree probabilities", "Section",
 CellChangeTimes->{{3.990708144209229*^9, 
  3.990708148104958*^9}},ExpressionUUID->"81cc1f8c-cc84-427e-91cc-\
8d4da7a48100"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"ProbT", " ", "=", " ", 
  RowBox[{"fH0", " ", "+", " ", 
   RowBox[{"Integrate", "[", 
    RowBox[{"fH1", ",", 
     RowBox[{"{", 
      RowBox[{"h", ",", "0", ",", "t1"}], "}"}]}], "]"}]}]}]], "Input",
