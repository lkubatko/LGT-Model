Cell[CellGroupData[{

Cell["Site pattern probabilities under the JC69 model", "Section",
 CellChangeTimes->{{3.990709851912656*^9, 
  3.9907098661608143`*^9}},ExpressionUUID->"85d66170-86f2-44ec-ad3a-\
c3abadbea9b6"],

Cell["\<\
Transition probabilities under JC for tree ((1:g1, 2:g1),3:g2) from the small \
phylogenetic trees website \
(https://www.coloradocollege.edu/aapps/ldg/small-trees/small-trees_0.html)\
\>", "Text",
 CellChangeTimes->{{3.990709881819818*^9, 
  3.990709888647663*^9}},ExpressionUUID->"9434589b-aa39-4a39-9f2a-\
836db2a90c77"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"ProbXXX", "[", 
    RowBox[{"g1_", ",", "g2_", ",", "\[Mu]_"}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"d0", ",", "d1", ",", "b0", ",", "b1", ",", "pxxx"}], "}"}], ",",
      "\[IndentingNewLine]", " ", 
     RowBox[{
      RowBox[{"d0", "=", " ", 
       RowBox[{
        RowBox[{"1", "/", "4"}], "+", 
        RowBox[{
         RowBox[{"3", "/", "4"}], "*", 
         RowBox[{"Exp", "[", 
          RowBox[{
           RowBox[{"-", "g1"}], "*", "\[Mu]"}], "]"}]}]}]}], ";", 
      "\[IndentingNewLine]", " ", 
      RowBox[{"d1", "=", " ", 
       RowBox[{
        RowBox[{"1", "/", "4"}], "-", 
        RowBox[{
         RowBox[{"1", "/", "4"}], "*", 
         RowBox[{"Exp", "[", 
          RowBox[{
           RowBox[{"-", "g1"}], "*", "\[Mu]"}], "]"}]}]}]}], ";", 
      "\[IndentingNewLine]", " ", 
      RowBox[{"b0", " ", "=", "  ", 
       RowBox[{
        RowBox[{"1", "/", "4"}], "+", 
        RowBox[{
         RowBox[{"3", "/", "4"}], "*", 
         RowBox[{"Exp", "[", 
          RowBox[{
           RowBox[{"-", 
            RowBox[{"(", 
             RowBox[{"g2", "-", "g1"}], ")"}]}], "*", "\[Mu]"}], "]"}]}]}]}], 
      ";", "\[IndentingNewLine]", " ", 
      RowBox[{"b1", " ", "=", " ", 
       RowBox[{
        RowBox[{"1", "/", "4"}], "-", 
        RowBox[{
         RowBox[{"1", "/", "4"}], "*", 
         RowBox[{"Exp", "[", 
          RowBox[{
           RowBox[{"-", 
            RowBox[{"(", 
             RowBox[{"g2", "-", "g1"}], ")"}]}], "*", "\[Mu]"}], "]"}]}]}]}], 
      ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
      RowBox[{"pxxx", " ", "=", "  ", 
       RowBox[{
        RowBox[{
         RowBox[{"b0", "^", "2"}], "*", 
         RowBox[{"d0", "^", "3"}]}], "+", 
        RowBox[{"3", "*", 
         RowBox[{"b0", "^", "2"}], "*", 
         RowBox[{"d1", "^", "3"}]}], "+", 
        RowBox[{"6", "*", "b0", "*", "b1", "*", 
         RowBox[{"d0", "^", "2"}], "*", "d1"}], "+", 
        RowBox[{"6", "*", "b0", "*", "b1", "*", "d0", "*", 
         RowBox[{"d1", "^", "2"}]}], "+", 
        RowBox[{"12", "*", "b0", "*", "b1", "*", 
         RowBox[{"d1", "^", "3"}]}], "+", 
        RowBox[{"3", "*", 
         RowBox[{"b1", "^", "2"}], "*", 
         RowBox[{"d0", "^", "3"}]}], "+", 
        RowBox[{"6", "*", 
         RowBox[{"b1", "^", "2"}], "*", 
         RowBox[{"d0", "^", "2"}], "*", "d1"}], "+", 
        RowBox[{"6", "*", 
         RowBox[{"b1", "^", "2"}], "*", "d0", "*", 
         RowBox[{"d1", "^", "2"}]}], "+", 
        RowBox[{"21", "*", 
         RowBox[{"b1", "^", "2"}], "*", 
         RowBox[{"d1", "^", "3"}]}]}]}]}]}], "\[IndentingNewLine]", "]"}]}], 
  ";"}]], "Input",
 CellChangeTimes->{{3.990709913882042*^9, 3.990709915112728*^9}},
 CellLabel->"In[44]:=",ExpressionUUID->"7f2fafc6-2c35-45c5-ac0e-3703beabadf3"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"ProbXXY", "[", 
    RowBox[{"g1_", ",", "g2_", ",", "\[Mu]_"}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"d0", ",", "d1", ",", "b0", ",", "b1", ",", "pxxy"}], "}"}], ",",
      "\[IndentingNewLine]", " ", 
     RowBox[{
      RowBox[{"d0", "=", " ", 
       RowBox[{
        RowBox[{"1", "/", "4"}], "+", 
        RowBox[{
         RowBox[{"3", "/", "4"}], "*", 
         RowBox[{"Exp", "[", 
          RowBox[{
           RowBox[{"-", "g1"}], "*", "\[Mu]"}], "]"}]}]}]}], ";", 
      "\[IndentingNewLine]", " ", 
      RowBox[{"d1", "=", " ", 
       RowBox[{
        RowBox[{"1", "/", "4"}], "-", 
        RowBox[{
         RowBox[{"1", "/", "4"}], "*", 
         RowBox[{"Exp", "[", 
          RowBox[{
           RowBox[{"-", "g1"}], "*", "\[Mu]"}], "]"}]}]}]}], ";", 
      "\[IndentingNewLine]", " ", 
      RowBox[{"b0", " ", "=", "  ", 
       RowBox[{
        RowBox[{"1", "/", "4"}], "+", 
        RowBox[{
         RowBox[{"3", "/", "4"}], "*", 
         RowBox[{"Exp", "[", 
          RowBox[{
           RowBox[{"-", 
            RowBox[{"(", 
             RowBox[{"g2", "-", "g1"}], ")"}]}], "*", "\[Mu]"}], "]"}]}]}]}], 
      ";", "\[IndentingNewLine]", " ", 
      RowBox[{"b1", " ", "=", " ", 
       RowBox[{
        RowBox[{"1", "/", "4"}], "-", 
        RowBox[{
         RowBox[{"1", "/", "4"}], "*", 
         RowBox[{"Exp", "[", 
          RowBox[{
           RowBox[{"-", 
            RowBox[{"(", 
             RowBox[{"g2", "-", "g1"}], ")"}]}], "*", "\[Mu]"}], "]"}]}]}]}], 
      ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
      RowBox[{"pxxy", "=", " ", 
       RowBox[{
        RowBox[{"6", "*", 
         RowBox[{"b0", "^", "2"}], "*", 
         RowBox[{"d0", "^", "2"}], "*", "d1"}], "+", 
        RowBox[{"6", "*", 
         RowBox[{"b0", "^", "2"}], "*", "d0", "*", 
         RowBox[{"d1", "^", "2"}]}], "+", 
        RowBox[{"12", "*", 
         RowBox[{"b0", "^", "2"}], "*", 
         RowBox[{"d1", "^", "3"}]}], "+", 
        RowBox[{"12", "*", "b0", "*", "b1", "*", 
         RowBox[{"d0", "^", "2"}], "*", "d1"}], "+", 
        RowBox[{"84", "*", "b0", "*", "b1", "*", "d0", "*", 
         RowBox[{"d1", "^", "2"}]}], "+", 
        RowBox[{"48", "*", "b0", "*", "b1", "*", 
         RowBox[{"d1", "^", "3"}]}], "+", 
        RowBox[{"30", "*", 
         RowBox[{"b1", "^", "2"}], "*", 
         RowBox[{"d0", "^", "2"}], "*", "d1"}], "+", 
        RowBox[{"102", "*", 
         RowBox[{"b1", "^", "2"}], "*", "d0", "*", 
         RowBox[{"d1", "^", "2"}]}], "+", 
        RowBox[{"84", "*", 
         RowBox[{"b1", "^", "2"}], "*", 
