}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Site pattern probabilities under the JC69 model", "Section",
 CellChangeTimes->{{3.990708181057926*^9, 
  3.990708191183419*^9}},ExpressionUUID->"25b040a8-5a1e-4fc9-89bc-\
1b4f47ad6f22"],

Cell["\<\
Transition probabilities under JC for tree (1:g, 2:g) derived analogously to \
small phylogenetic trees website \
(https://www.coloradocollege.edu/aapps/ldg/small-trees/small-trees_0.html). \
\>", "Text",
 CellChangeTimes->{{3.990708200371235*^9, 
  3.990708209022236*^9}},ExpressionUUID->"27b44854-210c-40ef-b0fe-\
43cd3f3324a0"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"ProbXX", "[", 
    RowBox[{"g_", ",", "\[Mu]_"}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"b0", ",", "b1", ",", "pxx"}], "}"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"b0", " ", "=", " ", 
       RowBox[{
        RowBox[{"1", "/", "4"}], "+", 
        RowBox[{
         RowBox[{"3", "/", "4"}], "*", 
         RowBox[{"Exp", "[", 
          RowBox[{
           RowBox[{"-", "g"}], "*", "\[Mu]"}], "]"}]}]}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"b1", "=", " ", 
       RowBox[{
        RowBox[{"1", "/", "4"}], "-", 
        RowBox[{
         RowBox[{"1", "/", "4"}], "*", 
         RowBox[{"Exp", "[", 
          RowBox[{
           RowBox[{"-", "g"}], "*", "\[Mu]"}], "]"}]}]}]}], ";", 
      "\[IndentingNewLine]", "\[IndentingNewLine]", 
      RowBox[{"pxx", " ", "=", 
       RowBox[{
        RowBox[{"b0", "^", "2"}], " ", "+", " ", 
        RowBox[{"3", "*", 
         RowBox[{"b1", "^", "2"}]}]}]}]}]}], "\[IndentingNewLine]", "]"}]}], 
  ";"}]], "Input",
 CellChangeTimes->{3.990708229969337*^9},
 CellLabel->"In[18]:=",ExpressionUUID->"d7bc6706-4ce3-4731-88c6-f7410ec235bd"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"ProbXY", "[", 
    RowBox[{"g_", ",", "\[Mu]_"}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"b0", ",", "b1", ",", "pxy"}], "}"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"b0", " ", "=", " ", 
       RowBox[{
        RowBox[{"1", "/", "4"}], "+", 
        RowBox[{
         RowBox[{"3", "/", "4"}], "*", 
         RowBox[{"Exp", "[", 
          RowBox[{
           RowBox[{"-", "g"}], "*", "\[Mu]"}], "]"}]}]}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"b1", "=", " ", 
       RowBox[{
        RowBox[{"1", "/", "4"}], "-", 
        RowBox[{
         RowBox[{"1", "/", "4"}], "*", 
         RowBox[{"Exp", "[", 
          RowBox[{
           RowBox[{"-", "g"}], "*", "\[Mu]"}], "]"}]}]}]}], ";", 
      "\[IndentingNewLine]", "\[IndentingNewLine]", 
      RowBox[{"pxy", " ", "=", 
       RowBox[{
        RowBox[{"6", "*", "b0", "*", "b1"}], " ", "+", " ", 
        RowBox[{"6", "*", 
         RowBox[{"b1", "^", "2"}]}]}]}]}]}], "\[IndentingNewLine]", "]"}]}], 
  ";"}]], "Input",
 CellChangeTimes->{3.9907082398900957`*^9},
 CellLabel->"In[19]:=",ExpressionUUID->"0d5e925d-3ab9-4849-81e5-b76181d588ea"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"ExpandAll", "[", 
  RowBox[{
   RowBox[{"ProbXX", "[", 
    RowBox[{"1", ",", 
     RowBox[{"4", "/", "3"}]}], "]"}], "+", 
   RowBox[{"ProbXY", "[", 
    RowBox[{"1", ",", 
     RowBox[{"4", "/", "3"}]}], "]"}]}], "]"}]], "Input",
 CellLabel->"In[20]:=",ExpressionUUID->"addcb6e5-ba49-4e8e-9979-f12ba896eab6"],

Cell[BoxData["1"], "Output",
 CellChangeTimes->{3.9907082484627*^9},
 CellLabel->"Out[20]=",ExpressionUUID->"009394c7-ee94-47f4-acd4-8e599a1619d8"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Pxx", "Subsection",
 CellChangeTimes->{{3.990708265715084*^9, 
  3.9907082803386297`*^9}},ExpressionUUID->"49528d2d-3f97-4aa3-9e8f-\
830416de6f73"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Pxx", " ", "=", " ", 
  RowBox[{"FullSimplify", "[", 
   RowBox[{
    RowBox[{"ExpandAll", "[", 
     RowBox[{"fH0", "*", 
      RowBox[{"ProbXX", "[", 
       RowBox[{"t1", ",", 
        RowBox[{"4", "/", "3"}]}], "]"}]}], "]"}], "+", 
    RowBox[{"ExpandAll", "[", 
     RowBox[{"Integrate", "[", 
      RowBox[{
       RowBox[{"fH1", "*", 
        RowBox[{"ProbXX", "[", 
         RowBox[{"h", ",", 
          RowBox[{"4", "/", "3"}]}], "]"}]}], ",", 
       RowBox[{"{", 
        RowBox[{"h", ",", "0", ",", "t1"}], "}"}]}], "]"}], "]"}]}], 
   "]"}]}]], "Input",
 CellChangeTimes->{{3.990708323523477*^9, 3.990708328006713*^9}, {
  3.99071270160468*^9, 3.99071270714353*^9}},
 CellLabel->"In[77]:=",ExpressionUUID->"b4bfce67-5121-4ea5-ae0c-e464beea950b"],

Cell[BoxData[
 FractionBox[
  RowBox[{"1", "+", 
   RowBox[{"3", " ", 
    SuperscriptBox["\[ExponentialE]", 
     RowBox[{
      RowBox[{"-", 
       FractionBox["2", "3"]}], " ", "t1", " ", 
      RowBox[{"(", 
       RowBox[{"4", "+", 
        RowBox[{"3", " ", "\[Lambda]"}]}], ")"}]}]]}], "+", 
   RowBox[{"3", " ", "\[Lambda]"}]}], 
  RowBox[{"4", "+", 
   RowBox[{"3", " ", "\[Lambda]"}]}]]], "Output",
 CellChangeTimes->{
  3.9907082888177032`*^9, 3.990708329881935*^9, {3.99071269873037*^9, 
   3.990712708840152*^9}, 3.99071275176276*^9},
 CellLabel->"Out[77]=",ExpressionUUID->"4f1c1dc4-7bcd-4751-9465-06d0a30c2dc5"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Pxy", "Subsection",
 CellChangeTimes->{{3.990708311381675*^9, 
  3.990708311965252*^9}},ExpressionUUID->"cc0325ed-e0d8-43f3-a2f0-\
a585fa309722"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Pxy", " ", "=", " ", 
  RowBox[{"FullSimplify", "[", 
   RowBox[{
    RowBox[{"ExpandAll", "[", 
     RowBox[{"fH0", "*", 
      RowBox[{"ProbXY", "[", 
       RowBox[{"t1", ",", 
        RowBox[{"4", "/", "3"}]}], "]"}]}], "]"}], "+", 
    RowBox[{"ExpandAll", "[", 
     RowBox[{"Integrate", "[", 
      RowBox[{
       RowBox[{"fH1", "*", 
        RowBox[{"ProbXY", "[", 
         RowBox[{"h", ",", 
          RowBox[{"4", "/", "3"}]}], "]"}]}], ",", 
       RowBox[{"{", 
        RowBox[{"h", ",", "0", ",", "t1"}], "}"}]}], "]"}], "]"}]}], 
   "]"}]}]], "Input",
 CellChangeTimes->{{3.990708337427721*^9, 3.990708340686413*^9}, {
  3.990712723029213*^9, 3.99071272533132*^9}},
 CellLabel->"In[78]:=",ExpressionUUID->"7e267a5c-48f8-4fff-96fc-623881d8490e"],

Cell[BoxData[
 FractionBox[
  RowBox[{"3", "-", 
   RowBox[{"3", " ", 
    SuperscriptBox["\[ExponentialE]", 
     RowBox[{
      RowBox[{"-", 
       FractionBox["2", "3"]}], " ", "t1", " ", 
      RowBox[{"(", 
       RowBox[{"4", "+", 
        RowBox[{"3", " ", "\[Lambda]"}]}], ")"}]}]]}]}], 
  RowBox[{"4", "+", 
   RowBox[{"3", " ", "\[Lambda]"}]}]]], "Output",
 CellChangeTimes->{
  3.9907083430526943`*^9, {3.990712728748159*^9, 3.9907127529828978`*^9}},
 CellLabel->"Out[78]=",ExpressionUUID->"f99b1c06-9f2b-4e66-9621-52e1a4504b0d"]
}, Open  ]]
}, Open  ]]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["\<\

The 3-taxon case\
\>", "Chapter",
 CellChangeTimes->{{3.990708396299222*^9, 
  3.990708411455599*^9}},ExpressionUUID->"313d8a7c-6d7f-4f72-9396-\
dff0e793bb37"],

Cell["\<\
Species tree:  S = ((1, 2), 3).
Arc notation: for ( i = 1,2,3 ), let e_i denote the arc incident to leaf i; \
let e_4 denote the interior arc.
Moreover, let t_1 < t_2 be the t-values of the interior vertices of S; let \
h_1 < h_2 be the t-values of the relevant transfer events; and let g_1 < g_2 \
be the t-values of the interior vertices of the resulting gene histories.\
\>", "Text",
 CellChangeTimes->{{3.9907085053015127`*^9, 3.990708595461742*^9}, {
  3.992932997067462*^9, 
  3.9929330055691757`*^9}},ExpressionUUID->"1953425e-a249-4d4b-958a-\
3e518742472b"],

Cell[CellGroupData[{

Cell["Gene history densities", "Section",
 CellChangeTimes->{{3.990708617410427*^9, 
  3.990708620930441*^9}},ExpressionUUID->"a002c9aa-53e5-44fe-85a9-\
b7339dde57f4"],

Cell["G1x: No transfer event; g1=t1, g2=t2", "Text",
 CellChangeTimes->{{3.990708636539774*^9, 
  3.9907086500419693`*^9}},ExpressionUUID->"bf651716-68ff-478e-aa2d-\
dd2c341957ea"],

Cell[BoxData[
 StyleBox[
  RowBox[{Cell[BoxData[
    RowBox[{"fG1x", " ", "=", "  ", 
     RowBox[{"Exp", "[", 
      RowBox[{
       RowBox[{"-", "\[Lambda]"}], "*", 
       RowBox[{"(", 
        RowBox[{"t1", "+", 
         RowBox[{"2", "*", "t2"}]}], ")"}]}], "]"}]}]], "Input",
    CellChangeTimes->{{3.961838697088386*^9, 3.961838720791635*^9}, {
     3.961839083031146*^9, 3.961839086999054*^9}},ExpressionUUID->
    "9eccc10d-1e61-44e6-a5d1-e28c0756ea9c"], ";"}], "InlineFormula"]], "Input",\

 CellChangeTimes->{3.990708659758972*^9},
 CellLabel->"In[27]:=",ExpressionUUID->"14cf530d-a8a5-4231-bee7-846184963bb0"],

Cell["\<\

G1a:  Precisely one relevant transfer in (0,t1) with transfer arc from e1 to \
e2; g1=h1, g2=t2; 0 < h1 < t1\
\>", "Text",
 CellChangeTimes->{{3.990708671341702*^9, 
  3.990708696505527*^9}},ExpressionUUID->"8aeff807-157c-4002-9f69-\
230879746378"],

Cell[BoxData[
 RowBox[{
  RowBox[{"fG1a", " ", "=", " ", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{"1", "/", "2"}], ")"}], "*", "\[Lambda]", "*", 
    RowBox[{"Exp", "[", 
     RowBox[{
      RowBox[{"-", "\[Lambda]"}], "*", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"2", "*", "t2"}], "+", "h1"}], ")"}]}], "]"}]}]}], 
  ";"}]], "Input",
 CellChangeTimes->{3.99070868480237*^9},
 CellLabel->"In[28]:=",ExpressionUUID->"1710c8c6-7229-4d41-9050-11a62b2e2683"],

Cell["\<\

G1b: Precisely one relevant transfer in (0,t1) with transfer arc from e2 to \
e1; g1=h1, g2=t2; 0 < h1 < t1\
\>", "Text",
 CellChangeTimes->{{3.9907087072176437`*^9, 
  3.990708714578289*^9}},ExpressionUUID->"7ed1a041-bebf-4e17-b290-\
07b3f5c3f8be"],

Cell[BoxData[
 RowBox[{
  RowBox[{"fG1b", " ", "=", " ", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{"1", "/", "2"}], ")"}], "*", "\[Lambda]", "*", 
    RowBox[{"Exp", "[", 
     RowBox[{
      RowBox[{"-", "\[Lambda]"}], "*", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"2", "*", "t2"}], "+", "h1"}], ")"}]}], "]"}]}]}], 
  ";"}]], "Input",
 CellChangeTimes->{3.990708724212696*^9},
 CellLabel->"In[29]:=",ExpressionUUID->"aca4eb42-078d-4dbe-855a-14a60b97ec7f"],

Cell["\<\

G1c: First relevant transfer in (0,t1) with transfer arc between e1 and e2 \
(direction irrelevant); second relevant transfer also in (0,t1) with transfer \
arc between e1 and e3 (direction irrelevant); g1=h1, g2=h2; 0 < h1 < t1 and 0 \
< h2 < t1-h1\
\>", "Text",
 CellChangeTimes->{{3.9907087392310457`*^9, 
  3.990708740222509*^9}},ExpressionUUID->"4eaa2074-c41a-48f2-baa6-\
502932f669a2"],

Cell[BoxData[
 RowBox[{
  RowBox[{"fG1c", " ", "=", " ", 
   RowBox[{"2", "*", 
    RowBox[{"\[Lambda]", "^", "2"}], "*", 
    RowBox[{"Exp", "[", 
     RowBox[{
      RowBox[{"-", "\[Lambda]"}], "*", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"3", "*", "h1"}], "+", 
        RowBox[{"2", "*", "h2"}]}], ")"}]}], "]"}]}]}], ";"}]], "Input",
 CellChangeTimes->{3.990708750542635*^9},
 CellLabel->"In[30]:=",ExpressionUUID->"1123808a-a924-4b9f-9d21-154f79a5e4b2"],

Cell["\<\

G1d: First relevant transfer in (0,t1) with transfer arc between e1 and e2 \
(direction irrelevant); second relevant transfer in (t1,t2) with transfer arc \
between e3 and e4 (direction irrelevant); g1=h1, g2=h2; 0 < h1 < t1 and 0 < \
h2 < t2-t1\
\>", "Text",
 CellChangeTimes->{{3.9907087550160913`*^9, 
  3.990708767618031*^9}},ExpressionUUID->"18e9cfda-a3e8-4363-94d2-\
5bf995360341"],

Cell[BoxData[
 RowBox[{
  RowBox[{"fG1d", " ", "=", " ", 
   RowBox[{"2", "*", 
    RowBox[{"\[Lambda]", "^", "2"}], "*", 
    RowBox[{"Exp", "[", 
     RowBox[{
      RowBox[{"-", "\[Lambda]"}], "*", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"2", "*", "t1"}], "+", "h1", "+", 
        RowBox[{"2", "*", "h2"}]}], ")"}]}], "]"}]}]}], ";"}]], "Input",
 CellChangeTimes->{3.990708771130927*^9},
 CellLabel->"In[31]:=",ExpressionUUID->"68273ed8-06f8-41af-a000-0083b56a60e3"],

Cell["\<\

G1y: First relevant transfer in (t1,t2) with transfer arc between e3 and e4 \
(direction does not matter); g1=t1, g2=h1, 0 < h1 < t2-t1\
\>", "Text",
 CellChangeTimes->{{3.990708781400671*^9, 
  3.9907087855969343`*^9}},ExpressionUUID->"f71d5d97-8b8f-4c1e-a123-\
2aad644601e7"],

Cell[BoxData[
 RowBox[{
  RowBox[{"fG1y", " ", "=", " ", 
   RowBox[{"2", "*", "\[Lambda]", "*", 
    RowBox[{"Exp", "[", 
     RowBox[{
      RowBox[{"-", "\[Lambda]"}], "*", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"3", "*", "t1"}], "+", 
        RowBox[{"2", "*", "h1"}]}], ")"}]}], "]"}]}]}], ";"}]], "Input",
 CellChangeTimes->{3.990708791762843*^9},
 CellLabel->"In[32]:=",ExpressionUUID->"034e4bc0-2e1c-4886-85c7-ee8d7d320ec5"],

Cell["\<\

G2a: Precisely one relevant transfer in (0,t1) with transfer arc from e1 to \
e3; g1 = h1, g2=t1; 0 < h1 < t1\
\>", "Text",
 CellChangeTimes->{{3.990708802842206*^9, 
  3.9907088031032124`*^9}},ExpressionUUID->"c3282f36-8574-43c6-aae2-\
6e9aea6060a5"],

Cell[BoxData[
 RowBox[{
